- when update:
  - load:
      - http://feda.websub.local/feda.xml
      - http://feda.websub.local/edugain-2.xml
- when request:
  - select:
  - pipe:
      - when accept text/html:
          - first
          - finalize:
              cacheDuration: PT12H
              validUntil: P10D
          - sign:
              key: sign.key
              cert: sign.crt
          - emit application/xml
          - break
      - when accept application/xml:
          - first
          - finalize:
              cacheDuration: PT12H
              validUntil: P10D
          - sign:
              key: sign.key
              cert: sign.crt
          - emit application/xml
          - break
      - when accept application/json:
          - discojson
          - emit application/json
          - break
